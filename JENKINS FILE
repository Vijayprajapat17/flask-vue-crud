pipeline{
    agent any
    
    environment {
        SCANNER_HOME= tool "sonarqube"
         DOCKER_USER = "vijay171202"
       
    }
    stages{
        stage("CLONE_REPOSITORY"){
            steps{
                git branch: 'main', url: 'https://github.com/Vijayprajapat17/flask-vue-crud.git'
            }
        }
      
        stage("CHECK-CODE-QUALITY"){
            steps{
                 withSonarQubeEnv( 'sonarqube') {
                 sh ''' $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=flask-vue-crud \
                        -Dsonar.projectKey=flask-vue-crud \
                         -Dsonar.sources=. \
                         -Dsonar.exclusions=client/**
                         '''
                 }

            }
        }
     stage('Build Images') {
            steps {
                sh '''
                docker build -t $DOCKER_USER/backend:latest ./server
                docker build -t $DOCKER_USER/frontend:latest ./client
                '''
            }
        }
         stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-cred',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh '''
                    echo $PASSWORD | docker login -u $USERNAME --password-stdin
                    '''
                }
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                docker push $DOCKER_USER/backend:latest
                docker push $DOCKER_USER/frontend:latest
                '''
            }
        }
     stage('Deploy with Docker Compose via SSM') {
    steps {
        sh '''
        aws ssm send-command \
        --instance-ids i-0cf8874226b082c95 \
        --document-name "AWS-RunShellScript" \
        --parameters 'commands=[
        "cd /home/ec2-user/flask-vue-crud",
        "docker compose pull",
        "docker compose down",
        "docker compose up -d"
        ]'
        '''
    }
}
      }
      
    }
